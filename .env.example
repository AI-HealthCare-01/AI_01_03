ENV=local
SECRET_KEY=change-me
TIMEZONE=Asia/Seoul

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Password123@!
DB_NAME=ai_health
DB_ROOT_PASSWORD=Password123@!
DB_EXPOSE_PORT=3306

DOCKER_USER=local
DOCKER_REPOSITORY=ai01
APP_VERSION=dev
AI_WORKER_VERSION=dev

OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
VISION_OPENAI_TIMEOUT_SEC=8
VISION_OPENAI_RETRY_COUNT=2
VISION_OPENAI_BACKOFF_SEC=0.5
VISION_OPENAI_MAX_TOKENS=500
VISION_DETECT_MODEL_PATH=yolov8n.pt
VISION_DETECT_CONF_THRES=0.25
VISION_MAX_DETECTIONS=5
VISION_TOP_K=3
VISION_MAX_IMAGE_SIDE=1280
VISION_ENABLE_FULL_IMAGE_FALLBACK=true
VISION_DISCLAIMER=본 서비스는 복약 보조 수단입니다.
VISION_CLASSIFIER_ENABLED=false
VISION_CLASSIFIER_MODEL_PATH=runs/classify/runs/classify/pill_cls_finetune_v1/weights/best.pt
VISION_CLASSIFIER_LABELS_PATH=runs/classify/runs/classify/pill_cls_finetune_v1/labels.json
VISION_MEDICATION_MAP_PATH=app/resources/vision_medication_map.json
VISION_CLASSIFIER_TOP_K=3
VISION_CLASSIFIER_WEIGHT=0.7
